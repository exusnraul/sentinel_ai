# ════════════════════════════════════════════════════════════════
#  Sentinel AI — .gitignore
#  Covers: Python (FastAPI/llama-cpp) · Next.js 16 · Chrome Extension
# ════════════════════════════════════════════════════════════════

# ─── macOS system files ─────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.AppleDouble
.LSOverride
.Spotlight-V100
.Trashes
Icon?
Thumbs.db
ehthumbs.db

# ─── Node / Next.js ─────────────────────────────────────────────
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Next.js build output (Turbopack & classic)
frontend/.next/
frontend/out/
frontend/build/
frontend/.turbo/

# TypeScript build cache
*.tsbuildinfo
next-env.d.ts

# npm / yarn / pnpm debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.pnpm-store/

# Coverage reports
/coverage
frontend/coverage/

# Vercel
.vercel

# ─── Python (FastAPI / llama-cpp / services) ────────────────────
# Byte-compiled / optimised files
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environments — all common names
venv/
.venv/
env/
.env/
ENV/
env.bak/
venv.bak/
.Python
# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
pip-log.txt
pip-delete-this-directory.txt
MANIFEST

# Unit test / coverage
.pytest_cache/
.coverage
htmlcov/
.tox/
nosetests.xml
coverage.xml
*.cover

# mypy / pyright / ruff caches
.mypy_cache/
.dmypy.json
.pyright/
.ruff_cache/

# ─── Secrets & environment variables ────────────────────────────
.env
.env.*
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem
*.key
*.p12
*.pfx
secrets.json
config/secrets*
api_keys*

# ─── ML model binaries (llama-cpp, PyTorch, ONNX, etc.) ─────────
# These are large and should never be committed
models/*.bin
models/*.gguf
models/*.ggml
models/*.pt
models/*.pth
models/*.onnx
models/*.h5
models/*.keras
models/*.safetensors
models/*.tflite
*.pkl
*.pickle
*.joblib
# Keep only the concept/reference PNG already in models/
!models/dashboard_concept.png

# ─── Databases & data files ─────────────────────────────────────
*.db
*.sqlite
*.sqlite3
data/*.csv
data/*.json
data/*.parquet
data/*.arrow

# ─── Logs ───────────────────────────────────────────────────────
*.log
logs/
backend/logs/

# ─── Screenshots / temp captures (mss / PIL service) ────────────
screenshots/
backend/screenshots/
*.png.tmp
captured_*.png

# ─── IDE / Editor ───────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.orig
.project
.classpath
*.sublime-workspace
*.sublime-project

# ─── Chrome extension build output ──────────────────────────────
sentient-gateway-browser-plugin-crome/dist/
sentient-gateway-browser-plugin-crome/build/
sentient-gateway-browser-plugin-crome/node_modules/
# Generated icon files (re-generated by generate_icons.py)
# Uncomment below if icons are auto-generated and shouldn't be committed:
# sentient-gateway-browser-plugin-crome/icons/

# ─── Misc ───────────────────────────────────────────────────────
.cache/
tmp/
temp/
*.bak
*.orig

./models/
.python-version
__pycache__
